#!/bin/bash
# check-installed-apps.sh (patched for new JSON schema, using Python instead of jq)
# - Reads .package as ARRAY (uses first item as package id for detection)
# - Robust JSON parsing via python3 (no grep/awk on JSON)
# - Rebuilds installed-apps.txt atomically (no substring sed removals)
# - Exact matching + proper quoting

set -euo pipefail

cd /

APPS_DIR="/opt/regataos-store/apps-list"
OUT_DIR="/opt/regataos-store/installed-apps"
OUT_FILE="${OUT_DIR}/installed-apps.txt"
TRIGGER="/tmp/apps-scripts/checkapp.txt"
TMP_FILE="${OUT_DIR}/installed-apps.new"

# Check if the OS Store Regata is running
if ps -C "regataosstore /opt/regataos-store" > /dev/null 2>&1; then

  # Check if the process should be started
  if test -e "$TRIGGER" ; then
    rm -f "$TRIGGER"

    # Create required directories/files
    mkdir -p "$HOME/.config/regataos-store"
    mkdir -p "$OUT_DIR"

    # Start fresh (atomic replace at the end)
    : > "$TMP_FILE"

    # ---- Install detection helpers ----
    is_installed_rpm() {
      local pkg="$1"
      rpm -q --quiet "$pkg" >/dev/null 2>&1
    }

    is_installed_flatpak() {
      local appid="$1"
      flatpak info "$appid" >/dev/null 2>&1
    }

    is_installed_snap() {
      local snapname="$1"
      snap list "$snapname" >/dev/null 2>&1
    }

    add_installed_nick() {
      local nick="$1"
      if [[ -z "$nick" ]]; then return 0; fi
      if [[ ! "$nick" =~ ^[A-Za-z0-9._-]+$ ]]; then
        echo "WARN: skipping unsafe nickname: $nick" >&2
        return 0
      fi
      printf '%s\n' "$nick" >> "$TMP_FILE"
    }

    # ---- Parse JSON files and check installation ----
    shopt -s nullglob
    for f in "$APPS_DIR"/*.json; do
      # Python prints lines: nickname<TAB>package_manager<TAB>pkg0
      while IFS=$'\t' read -r nick pm pkg0; do
        # trim/normalize
        nick="${nick//$'\r'/}"
        pm="${pm//$'\r'/}"
        pkg0="${pkg0//$'\r'/}"

        pm="$(echo "$pm" | tr '[:upper:]' '[:lower:]' | xargs || true)"
        pkg0="$(echo "$pkg0" | xargs || true)"

        [[ -z "$nick" || -z "$pm" || -z "$pkg0" ]] && continue

        if [[ "$pm" == "zypper" || "$pm" == "rpm" || "$pm" == "deb" ]]; then
          if is_installed_rpm "$pkg0"; then
            add_installed_nick "$nick"
          fi
        elif [[ "$pm" == "flatpak" ]]; then
          if is_installed_flatpak "$pkg0"; then
            add_installed_nick "$nick"
          fi
        elif [[ "$pm" == "snap" ]]; then
          if is_installed_snap "$pkg0"; then
            add_installed_nick "$nick"
          fi
        else
          echo "WARN: unknown package_manager '$pm' for $nick (file: $f)" >&2
        fi
      done < <(
        python3 - <<'PY' "$f"
import json, sys

path = sys.argv[1]
try:
    with open(path, "r", encoding="utf-8") as fh:
        data = json.load(fh)
except Exception:
    sys.exit(0)

# Each file is an array of objects
if not isinstance(data, list):
    sys.exit(0)

def first_pkg(pkg):
    # new schema: list, use first
    if isinstance(pkg, list):
        return str(pkg[0]).strip() if pkg else ""
    # legacy: string, return as-is
    if isinstance(pkg, str):
        return pkg.strip()
    return ""

for obj in data:
    if not isinstance(obj, dict):
        continue
    nick = (obj.get("nickname") or "").strip()
    pm = (obj.get("package_manager") or "").strip()
    pkg0 = first_pkg(obj.get("package"))
    if nick and pm and pkg0:
        # tab-separated to avoid parsing issues
        sys.stdout.write(f"{nick}\t{pm}\t{pkg0}\n")
PY
      )
    done

    # Deduplicate + remove blanks, then atomically write
    if test -s "$TMP_FILE"; then
      awk 'NF' "$TMP_FILE" | sort -u > "${TMP_FILE}.sorted"
      mv -f "${TMP_FILE}.sorted" "$OUT_FILE"
      rm -f "$TMP_FILE" || true
    else
      : > "$OUT_FILE"
      rm -f "$TMP_FILE" || true
    fi

    exit 0
  fi

else
  echo "Nothing to do..."
fi

sleep 1
exit 0
