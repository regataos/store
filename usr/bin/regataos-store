#!/bin/bash
# regataos-store launcher (patched)
# Goals:
# - Reduce unnecessary I/O (avoid chmod/rm loops over wildcards)
# - Reduce expensive repeated commands (glxinfo/groups)
# - Improve safety of /tmp operations (no rm -rf "$dir"/*, atomic writes)
# - Keep behavior compatible with current scripts

set -euo pipefail

umask 022

STORE_ROOT="/opt/regataos-store"
TMP_STORE="/tmp/regataos-store"
TMP_CFG="/tmp/regataos-configs/config"
TMP_PB="/tmp/progressbar-store"
APPS_SCRIPTS="/tmp/apps-scripts"
INSTALLED_FILE="${STORE_ROOT}/installed-apps/installed-apps.txt"

HOME_CFG="${HOME}/.config/regataos-store"
PLASMA_LOCALERC="${HOME}/.config/plasma-localerc"

# ----------------------------
# Helpers
# ----------------------------
mkdir_ensure() {
  local dir="$1"
  local mode="${2:-0777}"
  if [[ ! -d "$dir" ]]; then
    mkdir -p "$dir"
  fi
  # Only chmod when needed (stat is cheap; chmod causes FS writes)
  local cur
  cur="$(stat -c '%a' "$dir" 2>/dev/null || echo '')"
  if [[ "$cur" != "${mode#0}" && "$cur" != "$mode" ]]; then
    chmod "$mode" "$dir" || true
  fi
}

touch_ensure() {
  local file="$1"
  if [[ ! -e "$file" ]]; then
    mkdir -p "$(dirname "$file")"
    : > "$file"
  fi
}

write_atomic() {
  local file="$1"
  local content="$2"
  local dir tmp
  dir="$(dirname "$file")"
  tmp="${dir}/.$(basename "$file").tmp.$$"
  mkdir -p "$dir"
  printf '%s' "$content" > "$tmp"
  mv -f "$tmp" "$file"
}

# Safer cleanup of known files in progressbar dir
clear_progressbar_cache() {
  # do not delete the directory, only its direct children files
  if [[ -d "$TMP_PB" ]]; then
    find "$TMP_PB" -maxdepth 1 -type f -print0 2>/dev/null | xargs -0r rm -f --
  fi
}

# ----------------------------
# Create dirs / links
# ----------------------------
mkdir_ensure "$TMP_STORE" 0777
mkdir_ensure "$TMP_CFG" 0777
mkdir_ensure "$HOME_CFG" 0755

# /tmp/regataos-store/config -> ~/.config/regataos-store
if [[ ! -e "${TMP_STORE}/config" ]]; then
  mkdir -p "$TMP_STORE"
  ln -sf "$HOME_CFG" "${TMP_STORE}/config"
fi

# Optional Steam link
if [[ -d "${HOME}/.local/share/Steam/steamapps" ]]; then
  if [[ ! -e "${HOME_CFG}/steamapps" ]]; then
    ln -sf "${HOME}/.local/share/Steam/steamapps" "${HOME_CFG}/steamapps" || true
  fi
fi

# Installed apps file
touch_ensure "$INSTALLED_FILE"

# Progress bar directory
mkdir_ensure "$TMP_PB" 0777

# Status file in tmp config
mkdir -p "${TMP_STORE}/config"
write_atomic "${TMP_STORE}/config/status.txt" "inactive"

# ----------------------------
# Language files (only link once)
# ----------------------------
if [[ ! -e "${TMP_CFG}/plasma-localerc" ]]; then
  if [[ ! -e "$PLASMA_LOCALERC" && -e "/etc/xdg/plasma-localerc" ]]; then
    cp -f "/etc/xdg/plasma-localerc" "$PLASMA_LOCALERC" || true
  fi
  if [[ -e "$PLASMA_LOCALERC" ]]; then
    ln -sf "$PLASMA_LOCALERC" "${TMP_CFG}/plasma-localerc"
  fi
fi

if [[ ! -e "${TMP_CFG}/user-dirs.locale" && -e "${HOME}/.config/user-dirs.locale" ]]; then
  ln -sf "${HOME}/.config/user-dirs.locale" "${TMP_CFG}/user-dirs.locale" || true
fi

# Fix for zenity (kept as-is; consider restricting in the future)
xhost +si:localuser:root >/dev/null 2>&1 || true

# ----------------------------
# Clear cache (only when no downloads are active)
# ----------------------------
if ! pgrep -x wget >/dev/null 2>&1; then
  clear_progressbar_cache
fi

rm -f "${TMP_STORE}/go-installed" || true

# Clear GPUCache files (avoid expanding globs when dir empty)
GPUCACHE_DIR="${HOME}/.config/Regata OS Store/Default/GPUCache"
if [[ -d "$GPUCACHE_DIR" ]]; then
  find "$GPUCACHE_DIR" -maxdepth 1 -type f -print0 2>/dev/null | xargs -0r rm -f --
fi

# Check installed apps trigger + queue file (avoid repeated appends)
mkdir_ensure "$APPS_SCRIPTS" 0777
write_atomic "${APPS_SCRIPTS}/checkapp.txt" "installed"
touch_ensure "${TMP_PB}/queued-process"

# Create status file
touch_ensure "${HOME_CFG}/status.txt"
if [[ ! -s "${HOME_CFG}/status.txt" ]]; then
  write_atomic "${HOME_CFG}/status.txt" "stopped"
fi

# ----------------------------
# Permissions / policy checks
# ----------------------------
permission_store="user"
if [[ -e "/usr/share/regataos/enterprise-iso.txt" ]]; then
  permission_store="superuser"
fi
if id -nG | tr ' ' '\n' | grep -qx "guest-session"; then
  permission_store="superuser"
fi

# Reduce memory usage (kept)
export MALLOC_ARENA_MAX=2
export NODE_OPTIONS="--max-old-space-size=160"

# Detect GPU vendor once (glxinfo is expensive)
GPU_VENDOR="unknown"
if command -v glxinfo >/dev/null 2>&1; then
  GPU_VENDOR="$(glxinfo 2>/dev/null | grep -m1 -i 'vendor' || true)"
fi
USE_DISABLE_GPU="0"
if echo "$GPU_VENDOR" | grep -qi "Intel"; then
  USE_DISABLE_GPU="1"
fi

runStore_bg() {
  # Run helper scripts in background, detached from terminal.
  # (Keeps same behavior; avoids extra subshells.)
  "${STORE_ROOT}/scripts/progress-bar/capture-progress-download" >/dev/null 2>&1 &
  "${STORE_ROOT}/scripts/progress-bar/create-process-queues" >/dev/null 2>&1 &
  "${STORE_ROOT}/scripts/checkapp" >/dev/null 2>&1 &
  "${STORE_ROOT}/scripts/progress-bar/run-process-queues" >/dev/null 2>&1 &
  sudo "${STORE_ROOT}/scripts/progress-bar/capture-progress-download-snap" >/dev/null 2>&1 &
  sudo "${STORE_ROOT}/scripts/progress-bar/capture-progress-download-flatpak" >/dev/null 2>&1 &
}

cleanup() {
  rm -f "${APPS_SCRIPTS}/store-superuser.txt" || true
}
trap cleanup EXIT

if [[ "$permission_store" == "superuser" ]]; then
  rm -f "${APPS_SCRIPTS}/store-superuser.txt"
  xdg-su -c "regataos_store" || true

  if [[ -e "${APPS_SCRIPTS}/store-superuser.txt" ]]; then
    # Must be created by root to proceed (same logic)
    if ls -l "${APPS_SCRIPTS}/store-superuser.txt" 2>/dev/null | grep -q " root "; then
      if [[ "$USE_DISABLE_GPU" == "1" ]]; then
        regataosstore --disable-gpu /opt/regataos-store >/dev/null 2>&1 &
      else
        regataosstore /opt/regataos-store >/dev/null 2>&1 &
      fi
      sleep 1
      runStore_bg
      exit 0
    fi
  fi
  exit 0
else
  if [[ "$USE_DISABLE_GPU" == "1" ]]; then
    regataosstore --disable-gpu /opt/regataos-store >/dev/null 2>&1 &
  else
    regataosstore /opt/regataos-store >/dev/null 2>&1 &
  fi
  sleep 1
  runStore_bg
fi
